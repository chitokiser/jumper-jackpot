# Server
NODE_ENV=development
PORT=8787

# Firebase Admin (choose one auth method)
# 1) Service account env vars
FIREBASE_PROJECT_ID=jumper-b15aa
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=jumper-b15aa.firebasestorage.app

# 2) Or use GOOGLE_APPLICATION_CREDENTIALS in your shell
# set GOOGLE_APPLICATION_CREDENTIALS=C:\path\service-account.json

# Chain
CHAIN_ID=204
RPC_URL=https://opbnb-mainnet-rpc.bnbchain.org
PAYMENT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
HEX_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENT_EVENT_NAME=PaymentSettled
HEX_DECIMALS=18
CONFIRMATIONS=1
START_BLOCK=0
POLL_INTERVAL_MS=8000

# Security / Rules
JACKPOT_HMAC_SECRET=replace_with_long_random_secret
ADMIN_EXCLUDED_ADDRESSES=0x1111111111111111111111111111111111111111
SELF_PAYMENT_BLOCK=true
REPEAT_LIMIT_PER_10MIN=20

# Jackpot Defaults
DEFAULT_ENABLED=true
DEFAULT_PAYOUT_SCALE=100000
DEFAULT_MAX_WIN_PERCENT=50
DEFAULT_MIN_PAYMENT_HEX=0
DEFAULT_MIN_CLAIM_HEX=30
DEFAULT_DAILY_MAX_PAYOUT_HEX=50000

# Withdrawal
HOT_WALLET_PRIVATE_KEY=0xabc
AUTO_APPROVE_WITHDRAW=false
WITHDRAW_GAS_LIMIT=120000

ADMIN_API_KEY=replace_admin_api_key
